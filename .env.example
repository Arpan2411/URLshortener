# ============================================
# Application Configuration
# ============================================

# Application environment
NODE_ENV=development

# Server port
PORT=3000

# Base URL of the application
BASE_URL=http://localhost:3000


# ============================================
# MongoDB Configuration
# ============================================

# MongoDB connection URI
MONGODB_URI=mongodb://mongodb:27017/urlshortner

# MongoDB credentials
MONGO_USER=<your_mongodb_username>
MONGO_PASSWORD=<your_mongodb_password>


# ============================================
# Redis Configuration
# ============================================

# Redis server host
REDIS_HOST=redis

# Redis server port
REDIS_PORT=6379

# Redis password
REDIS_PASSWORD=<your_redis_password>


# ============================================
# Authentication & Security
# ============================================

# JWT secret (minimum 32 characters recommended)
JWT_SECRET=<your_secure_jwt_secret>

# Password hashing strength
SALT_ROUNDS=10


# ============================================
# URL Shortener Settings
# ============================================

# Length of generated short code
SHORT_URL_LENGTH=6

# Characters used for Base62 encoding
BASE62_CHARSET=0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ


# ============================================
# Redis Cache Configuration
# ============================================

# Enable or disable Redis caching
CACHE_ENABLED=true

# Cache TTL (in seconds)
CACHE_TTL=3600


# ============================================
# Rate Limiter Configuration
# ============================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Enable burst protection
RATE_LIMIT_BURST_ENABLED=true

# Time window (milliseconds)
RATE_LIMIT_WINDOW_MS=600000

# Maximum requests allowed per window
RATE_LIMIT_MAX_REQUESTS=100

# Warning threshold (0-1)
RATE_LIMIT_WARNING_THRESHOLD=0.7

# Critical threshold (0-1)
RATE_LIMIT_CRITICAL_THRESHOLD=0.9